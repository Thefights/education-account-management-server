ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
AllowedHosts=*
AppInfo__Name=EduWallet
AppInfo__Version=1.0.0
UrlsConfig__FrontendUrl=https://frontend.example.com
DatabaseConfig__ConnectionString=Server=your-rds-endpoint.amazonaws.com,1433;Database=AgileProjectDb;User Id=your_user;Password=your_password;TrustServerCertificate=True;
JwtConfig__SecretKey=replace-with-at-least-32-characters-secret-key
JwtConfig__ExpireTimeInMinutes=30
JwtConfig__Issuer=edu-wallet
JwtConfig__Audience=edu-wallet-client
Microsoft365Config__ClientId=00000000-0000-0000-0000-000000000000
Microsoft365Config__TenantId=common
RefreshTokenConfig__CookieName=refreshToken
RefreshTokenConfig__Domain=api.example.com
RefreshTokenConfig__Secure=true
RefreshTokenConfig__SameSite=None
RefreshTokenConfig__ExpirationDays=7
BackgroundJobConfig__DataCleanupIntervalHours=24
BackgroundJobConfig__AuthTransientRetentionDays=90
BackgroundJobConfig__OutboxRetentionDays=180
BackgroundJobConfig__CleanupBatchSize=500
PerformanceMiddlewareConfig__SlowRequestThresholdMs=1000
PerformanceMiddlewareConfig__ResponseTimeHeaderName=X-Response-Time-Ms
PerformanceMiddlewareConfig__ExcludedPathPrefixes__0=/swagger
ResilienceConfig__EmailTimeoutSeconds=10
ResilienceConfig__EmailRetryCount=3
ResilienceConfig__EmailCircuitBreakSeconds=60
ResilienceConfig__EmailRateLimitPerMinute=30
ResilienceConfig__R2UploadTimeoutSeconds=60
ResilienceConfig__R2UploadRetryCount=2
ResilienceConfig__R2DeleteTimeoutSeconds=10
ResilienceConfig__R2DeleteRetryCount=1
RateLimitConfig__GeneralPermitLimitPerMinute=120
RateLimitConfig__AuthSensitivePermitLimitPerMinute=10
RateLimitConfig__AuthSensitivePermitLimitPerHour=20
RateLimitConfig__QueueLimit=0
DataCacheConfig__SettingsTtlMinutes=15
EmailConfig__ApiKey=replace-with-email-provider-api-key
EmailConfig__FromEmail=no-reply@example.com
EmailConfig__FromDisplayName=EduWallet
RedisConfig__Host=redis.example.com:6379
RedisConfig__InstanceName=edu-wallet:
RedisConfig__Password=replace-with-redis-password
RedisConfig__AbortOnConnectFail=true
RedisConfig__ConnectRetry=1
RedisConfig__ConnectTimeoutMs=3000
RedisConfig__SyncTimeoutMs=3000
RedisConfig__ReconnectRetryMs=3000
R2Config__AccountId=replace-with-cloudflare-r2-account-id
R2Config__AccessKeyId=replace-with-cloudflare-r2-access-key-id
R2Config__SecretAccessKey=replace-with-cloudflare-r2-secret-access-key
R2Config__Bucket=edu-wallet
R2Config__PublicBaseUrl=https://pub-example.r2.dev
